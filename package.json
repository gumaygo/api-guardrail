{
  "name": "api-guardrail",
  "version": "1.1.0",
  "description": "API testing framework with contract validation, HTML reports, and load testing.",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:report": "jest --reporters=default --reporters=jest-html-reporters",
    "load-test": "k6 run scripts/load-test.js"
  },
  "jest": {
    "setupFilesAfterEnv": ["./jest.setup.js"],
    "reporters": [
      "default",
      [
        "jest-html-reporters",
        {
          "publicPath": "./docs/reports",
          "filename": "index.html",
          "expand": true
        }
      ]
    ]
  },
  "keywords": [
    "qa-automation",
    "api-testing",
    "contract-testing",
    "jest",
    "zod",
    "nodejs",
    "load-testing"
  ],
  "author": "gumaygo",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.13.6",
    "axios-retry": "^4.5.0",
    "chalk": "^4.1.2",
    "jest": "^30.2.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "dotenv": "^17.3.1",
    "jest-html-reporters": "^3.1.7",
    "jsonwebtoken": "^9.0.3"
  }
}
